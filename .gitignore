# --- Jekyll build artifacts ---
_site/
.sass-cache/
.jekyll-cache/
.jekyll-metadata

# Bundler
.bundle/
vendor/bundle/

# Node (if you add tooling)
node_modules/
.pnpm-store/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS cruft
.DS_Store
Thumbs.db
ehthumbs.db
Icon?
desktop.ini

# VS Code
.vscode/
.history/

# Logs
*.log

# --- Windows ADS sidecar files that slipped into the tree ---
# They often appear as `filename<private-char>Zone.Identifier`
# or similar when zipped/moved between Windows and WSL.
**/*Zone.Identifier*
